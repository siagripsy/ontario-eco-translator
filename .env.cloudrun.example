APP_NAME=Ontario Eco-Translator
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8080
API_PREFIX=

DB_MODE=cloud
DB_NAME=NTPower
DB_USER=your_sqlserver_user
DB_PASSWORD=your_sqlserver_password
CLOUD_SQL_CONNECTION_NAME=your-project:your-region:your-instance
CLOUD_SQL_IP_TYPE=public

GOOGLE_API_KEY=your_google_api_key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

CHROMA_COLLECTION_NAME=ntpower_tariff_chunks
CHROMA_PERSIST_DIR=/tmp/chroma_db
UPLOADS_DIR=/tmp/uploads

CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVAL_K=4
MAX_SOURCE_SNIPPET_LENGTH=300
