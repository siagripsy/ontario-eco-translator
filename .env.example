APP_NAME=Ontario Eco-Translator
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000
API_PREFIX=

DB_MODE=local
DB_HOST=localhost
DB_PORT=1433
DB_NAME=NTPower
DB_USER=sa
DB_PASSWORD=your_password
DB_DRIVER=ODBC Driver 18 for SQL Server

# Cloud Run / Cloud SQL for SQL Server
CLOUD_SQL_CONNECTION_NAME=your-project:your-region:your-instance
CLOUD_SQL_IP_TYPE=private

# Optional explicit Alembic URL, especially useful for cloud migrations.
ALEMBIC_DATABASE_URL=

GOOGLE_API_KEY=your_google_api_key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

CHROMA_COLLECTION_NAME=ntpower_tariff_chunks
CHROMA_PERSIST_DIR=chroma_db
UPLOADS_DIR=data/uploads

CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVAL_K=4
MAX_SOURCE_SNIPPET_LENGTH=300
